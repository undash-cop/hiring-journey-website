APP_NAME=Hiring Journey API
APP_ENV=production
API_BASE_URL=https://api.hiringjourney.com

# Use Postgres in production (example)
DATABASE_URL=postgresql+psycopg://api_user:change_me@db-host:5432/hiring_journey

# Frontend origins allowed to call this API
CORS_ORIGINS=https://hiringjourney.com,https://www.hiringjourney.com,https://staging.hiringjourney.com

LOG_LEVEL=INFO
# Per-IP /admin rate limit (in-memory; set 0 to disable)
ADMIN_RATE_LIMIT_PER_MINUTE=120

# Keycloak
KEYCLOAK_SERVER_URL=https://secure.undash-cop.com
KEYCLOAK_REALM=hiringjourney
KEYCLOAK_AUDIENCE=hiringjourney-app
