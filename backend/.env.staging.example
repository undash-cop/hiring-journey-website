APP_NAME=Hiring Journey API (Staging)
APP_ENV=staging
API_BASE_URL=https://api-staging.hiringjourney.com

# Compose stack: use postgresql+psycopg://POSTGRES_USER:POSTGRES_PASSWORD@db:5432/POSTGRES_DB
DATABASE_URL=postgresql+psycopg://hj_staging:change_me@db:5432/hiring_journey_staging

CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://staging.hiringjourney.com,https://deploy-preview--hiringjourney.netlify.app

LOG_LEVEL=INFO
ADMIN_RATE_LIMIT_PER_MINUTE=120

KEYCLOAK_SERVER_URL=https://secure.undash-cop.com
KEYCLOAK_REALM=hiringjourney
KEYCLOAK_AUDIENCE=hiringjourney-app

# Docker Compose TLS (host paths on staging VM)
SSL_CERT_PATH=/etc/letsencrypt/live/api-staging.hiringjourney.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/api-staging.hiringjourney.com/privkey.pem

POSTGRES_DB=hiring_journey_staging
POSTGRES_USER=hj_staging
POSTGRES_PASSWORD=change_me
