# API env
APP_NAME=Hiring Journey API
APP_ENV=production
API_BASE_URL=https://api.hiringjourney.com
DATABASE_URL=postgresql+psycopg://hj_api:change_me@db:5432/hiring_journey
CORS_ORIGINS=https://hiringjourney.com,https://www.hiringjourney.com
KEYCLOAK_SERVER_URL=https://secure.undash-cop.com
KEYCLOAK_REALM=hiringjourney
KEYCLOAK_AUDIENCE=hiringjourney-app

# Postgres bootstrap
POSTGRES_DB=hiring_journey
POSTGRES_USER=hj_api
POSTGRES_PASSWORD=change_me

# TLS cert/key paths on host
SSL_CERT_PATH=/etc/letsencrypt/live/api.hiringjourney.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/api.hiringjourney.com/privkey.pem
