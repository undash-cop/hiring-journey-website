APP_NAME=Hiring Journey API
APP_ENV=development
API_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///./hiring_journey.db
# Production (Postgres): postgresql+psycopg://user:password@host:5432/database_name
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://hiringjourney.com,https://www.hiringjourney.com,https://staging.hiringjourney.com,https://api-staging.hiringjourney.com
LOG_LEVEL=INFO
# Admin API rate limit per client IP (sliding 60s window); 0 = disabled
ADMIN_RATE_LIMIT_PER_MINUTE=120

KEYCLOAK_SERVER_URL=https://secure.undash-cop.com
KEYCLOAK_REALM=hiringjourney
KEYCLOAK_AUDIENCE=hiringjourney-app
# Must match the Keycloak client id (also accepted via token `azp` when aud is "account").
