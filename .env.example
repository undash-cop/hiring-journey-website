# Keycloak (OIDC) — used by marketing CTAs and /auth/callback
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.example.com
NEXT_PUBLIC_KEYCLOAK_REALM=your-realm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=your-client-id

# Optional: force OAuth redirect_uri to this origin (no trailing slash). Use when the site is always served
# at a canonical URL, e.g. https://hiringjourney.com — must match Keycloak "Valid redirect URIs".
# Leave unset for local dev (uses window.location.origin → http://localhost:3000/auth/callback).
# NEXT_PUBLIC_KEYCLOAK_REDIRECT_ORIGIN=https://hiringjourney.com

# Optional: explicit app origin after Keycloak callback (defaults to NEXT_PUBLIC_APP_SUBDOMAIN_URL)
# NEXT_PUBLIC_APP_POST_LOGIN_ORIGIN=https://app.example.com

# Application URL
# For local development: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App Subdomain Configuration
# App subdomain URL - used for API calls from marketing site to app.hiringjourney.com
# Pricing and Signup pages stay on marketing site and call app APIs
NEXT_PUBLIC_APP_SUBDOMAIN_URL=https://app.hiringjourney.com

# Optional: Redirect login page to app subdomain
# Set to "true" to enable automatic redirect from /auth/login to app subdomain
# When enabled: /auth/login → https://app.hiringjourney.com/login
# Note: Pricing and Signup stay on marketing site for SEO benefits
# NEXT_PUBLIC_REDIRECT_LOGIN_TO_APP=false

# Backend API URL (when backend is ready)
# NEXT_PUBLIC_API_URL=https://api.your-domain.com

#  (optional)
# Google Analytics 4 (GA4) - Get your Measurement ID from Google Analytics dashboard
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Plausible Analytics (privacy-friendly alternative)
# Your domain name for Plausible (e.g., hiringjourney.com)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Payment Gateway (when ready)
# RAZORPAY_KEY_ID=your-razorpay-key-id
# RAZORPAY_KEY_SECRET=your-razorpay-secret

# Email Service (when ready)
# SENDGRID_API_KEY=your-sendgrid-api-key
# EMAIL_FROM=noreply@hiringjourney.com
