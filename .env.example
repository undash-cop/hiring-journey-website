# Keycloak (OIDC) — browser opens this host for sign-in (URLs like …/realms/{realm}/protocol/openid-connect/auth).
# Use a dedicated auth host (e.g. https://auth.hiringjourney.com) if you do not want the apex domain to serve Keycloak.
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.example.com
NEXT_PUBLIC_KEYCLOAK_REALM=your-realm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=your-client-id

# --- Keycloak client (realm → Clients → your client) checklist ---
# Valid redirect URIs (examples; add every deploy host you use):
#   https://hiringjourney.com/auth/callback
#   https://hiringjourney.com/app/login
#   http://localhost:3000/auth/callback
#   http://localhost:3000/app/login
#   http://localhost:3001/auth/callback   (if Next dev binds to 3001)
#   http://localhost:3001/app/login
# Web origins:
#   https://hiringjourney.com
#   http://localhost:3000
#   http://localhost:3001
# Valid post logout redirect URIs (logout lands on marketing home — NEXT_PUBLIC_APP_URL + /):
#   https://hiringjourney.com
#   https://hiringjourney.com/
# Silent SSO (static file):
#   https://hiringjourney.com/silent-check-sso.html
# See also: docs/deployment/keycloak.md

# Optional: force OAuth redirect_uri to this origin (no trailing slash). Use when the site is always served
# at a canonical URL, e.g. https://hiringjourney.com — must match Keycloak "Valid redirect URIs".
# Leave unset for local dev (uses window.location.origin → http://localhost:3000/auth/callback).

# Application URL
# For local development: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=v1.0.0

# Backend API URL (required for CI/production builds)
# Local: http://localhost:8000
# Production: https://api.hiringjourney.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Phase 2+ mock APIs for local demos only (never enable in production)
# NEXT_PUBLIC_USE_MOCK_API=true
# Optional fallback for Keycloak logout redirect if NEXT_PUBLIC_APP_URL is unset in some envs
# NEXT_PUBLIC_AUTH_URL=https://your-domain.com

#  (optional)
# Google Analytics 4 (GA4) - Get your Measurement ID from Google Analytics dashboard
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Plausible Analytics (privacy-friendly alternative)
# Your domain name for Plausible (e.g., hiringjourney.com)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Payment Gateway (when ready)
# RAZORPAY_KEY_ID=your-razorpay-key-id
# RAZORPAY_KEY_SECRET=your-razorpay-secret

# Email Service (when ready)
# SENDGRID_API_KEY=your-sendgrid-api-key
# EMAIL_FROM=noreply@hiringjourney.com
