{
  "name": "hiring-journey-website",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "validate:env": "node scripts/validate-build-env.mjs",
    "validate:env:parity": "node scripts/validate-env-parity.mjs",
    "smoke:api": "bash scripts/smoke-api.sh",
    "build": "node scripts/validate-build-env.mjs && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "api:spec:download": "curl -fsSL http://localhost:8000/openapi.json -o openapi/hiring-journey-api.openapi.json",
    "api:client:generate": "openapi-generator-cli generate -i openapi/hiring-journey-api.openapi.json -g typescript-axios -o lib/generated/api-client --additional-properties=useSingleRequestParameter=true,withSeparateModelsAndApi=true,apiPackage=apis,modelPackage=models",
    "api:sync": "npm run api:spec:download && npm run api:client:generate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@next/third-parties": "^16.2.1",
    "@tanstack/react-query": "^5.95.2",
    "autoprefixer": "^10.4.27",
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "keycloak-js": "^26.2.3",
    "lucide-react": "^0.468.0",
    "next": "^16.2.1",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^3.4.17",
    "zod": "^3.24.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@openapitools/openapi-generator-cli": "^2.25.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "typescript": "^5.7.2"
  }
}
